# Django
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
DJANGO_SETTINGS_MODULE=inspi.settings.local

# Database (matches docker-compose.yml)
DB_NAME=inspi
DB_USER=inspi
DB_PASSWORD=inspi
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Google GenAI (get key from https://aistudio.google.com/apikey)
GOOGLE_GENAI_API_KEY=

# GCP
# GOOGLE_CLOUD_PROJECT=your-project-id
# GCS_BUCKET_NAME=gruppenstunde-media
# APPENGINE_URL=https://gruppenstunde.de
